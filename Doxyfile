# Doxyfile для лабораторной работы по ПСП

PROJECT_NAME           = "Лабораторная работа: ПСП"
PROJECT_BRIEF          = "Генерация и тестирование псевдослучайных последовательностей"
PROJECT_NUMBER         = 1.0
OUTPUT_DIRECTORY       = docs/doxygen
CREATE_SUBDIRS         = NO
OUTPUT_LANGUAGE        = Russian

# Входные файлы
INPUT                  = generator.h tests.h main.cpp docs/PSP.md
INPUT_ENCODING         = UTF-8
FILE_PATTERNS          = *.h *.cpp *.md
RECURSIVE              = NO

# Извлечение документации
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
BRIEF_MEMBER_DESC      = YES
REPEAT_BRIEF           = YES
ALWAYS_DETAILED_SEC    = NO
INLINE_INHERITED_MEMB  = YES
SORT_MEMBER_DOCS       = YES
SORT_BRIEF_DOCS        = NO

# Javadoc-стиль (@brief, @param, @return)
JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = NO
MULTILINE_CPP_IS_BRIEF = NO
INHERIT_DOCS           = YES
SEPARATE_MEMBER_PAGES  = NO

# HTML
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html
HTML_COLORSTYLE_HUE    = 210
HTML_COLORSTYLE_SAT    = 120
HTML_COLORSTYLE_GAMMA  = 80
HTML_TIMESTAMP         = YES
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
SEARCHENGINE           = YES

# LaTeX / RTF / Man — отключены
GENERATE_LATEX         = NO
GENERATE_RTF           = NO
GENERATE_MAN           = NO

# Диаграммы классов
HAVE_DOT               = NO
CLASS_DIAGRAMS         = YES

# Предупреждения
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO

# Кодировка
DOXYFILE_ENCODING      = UTF-8
